# ── LLM Providers ─────────────────────────────────────────────────────────────
# Set the keys for the providers you want to use.
# At least one key is required. Others can be left blank.

GROQ_API_KEY=gsk_***
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Default provider used when no provider is specified in the request.
# Choices: groq | anthropic | openai
DEFAULT_LLM_PROVIDER=groq

# Optional: override the default model for the chosen provider.
# Leave blank to use the provider's recommended default.
# Examples: llama-3.3-70b-versatile | claude-sonnet-4-6 | gpt-4o
DEFAULT_LLM_MODEL=llama-3.3-70b-versatile

# ── Screener.in Credentials ────────────────────────────────────────────────────
# Required for authenticated scraping (unlocks full financial data).
# Register free at https://www.screener.in
SCREENER_USERNAME=your_email@example.com
SCREENER_PASSWORD=your_password_here

# ── App ────────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
REQUEST_TIMEOUT=30
