# ── LLM Providers ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# ── Screener.in credentials ───────────────────────────────────────────────────
SCREENER_USERNAME=your@email.com
SCREENER_PASSWORD=yourpassword

# ── LLM Routing (task-type based) ────────────────────────────────────────────
# reasoning   = deep business analysis, valuation, reports  (gpt-5-mini)
# execution   = data fetch, classification, quick summaries (gpt-4.1-mini)
# fast        = alerts, intent routing, short tasks         (groq llama)
REASONING_PROVIDER=openai
REASONING_MODEL=gpt-5-mini

EXECUTION_PROVIDER=openai
EXECUTION_MODEL=gpt-4.1-mini

FAST_PROVIDER=groq
FAST_MODEL=llama-3.3-70b-versatile

# ── Channels ──────────────────────────────────────────────────────────────────
# Telegram: get token from @BotFather
TELEGRAM_BOT_TOKEN=

# Slack: from api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_APP_TOKEN=xapp-...      # for socket mode

# Discord: from discord.com/developers/applications
DISCORD_BOT_TOKEN=

# WhatsApp (Baileys bridge — no token, uses QR code scan)
# No credentials needed. On first run, scan the QR code printed in the terminal.
# Session is saved to baileys_bridge/auth_info_baileys/ for automatic reconnect.
WHATSAPP_BRIDGE_PORT=3000     # Node.js bridge HTTP port
WHATSAPP_WEBHOOK_PORT=8080    # Python webhook receiver port

# ── App settings ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
REQUEST_TIMEOUT=30
